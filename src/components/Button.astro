---
interface Props {
  title: string;
  extraClass?: string;
  href?: string;
}

const { title, extraClass = '', href } = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class=`btn ${extraClass} btn-reset`
  {...href ? { 'data-astro-prefetch': 'false' } : { type: 'button' }}
  >{title}</Tag
>
