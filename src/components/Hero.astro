---
import { promoData } from '@data/promo';
import Button from './Button.astro';

interface Props {
  id: string;
  class: string;
}

const { id, class: extraClass = '' } = Astro.props;
---

<section id={id} class:list={extraClass}>
  <div class="hero__container container">
    <div class="hero__content">
      <span class="hero__badge">10 years anniversary</span>
      <h1 class="hero__title">
        {promoData.title}
      </h1>
      <h2 class="hero__subtitle">{promoData.releaseName}</h2>
      <p class="hero__description">{promoData.plot}</p>
    </div>
    <div class="hero__actions">
      <Button title="О релизе" extraClass="btn--primary" href="#details" />
      <Button title="Слушать релиз" extraClass="btn--primary" href="#media" />
    </div>
    <a
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="hero__social-link"
    >
      VK Community ↗
    </a>
  </div>
</section>
